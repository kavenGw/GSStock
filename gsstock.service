[Unit]
Description=GSStock Server
After=network.target

[Service]
Type=simple
User=gsstock
Group=gsstock
WorkingDirectory=/opt/gsstock
Environment=PATH=/opt/gsstock/venv/bin:/usr/bin
EnvironmentFile=/opt/gsstock/.env
ExecStart=/opt/gsstock/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 "app:create_app()"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
