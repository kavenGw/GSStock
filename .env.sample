# GSStock 环境配置示例
# 复制此文件为 .env 并修改配置

# ============ 只读模式 ============
# 只读模式下：不从服务器获取数据，不修改 stock.db，但可以修改 private.db
# 适用于无网络环境或仅查看历史数据
READONLY_MODE=false

# ============ 密钥配置 ============
# Flask 密钥，用于 session 加密，留空则自动生成
SECRET_KEY=

# ============ 数据库配置 ============
# 公共数据库路径（股票列表、缓存、分类）
# DATABASE_URL=sqlite:///data/stock.db

# 私有数据库路径（持仓、交易、配置）
# PRIVATE_DATABASE_URL=sqlite:///data/private.db

# ============ 数据源 API 密钥（可选） ============
# A股数据源（新浪/腾讯/东方财富）无需密钥，开箱即用
# 美股/港股默认使用 yfinance（无需密钥），配置以下密钥可启用多数据源负载均衡

# Twelve Data — 免费: 8请求/分钟, 800请求/天（美股/港股）
# 注册: https://twelvedata.com/register
# TWELVE_DATA_API_KEY=

# Polygon.io — 免费: 5请求/分钟（仅美股）
# 注册: https://polygon.io/dashboard/signup
# POLYGON_API_KEY=

# ============ LLM 分析配置（可选） ============
# 智谱 GLM 大模型，配置后自动启用 AI 分析功能
# Flash 层 (glm-4-flash): 快速任务
# Premium 层 (glm-4): 深度分析，预算用尽自动降级到 Flash
# ZHIPU_API_KEY=

# LLM 日预算上限（美元），不配置则无上限
# LLM_DAILY_BUDGET=5.0

# LLM API 请求超时（秒），默认 300
# LLM_REQUEST_TIMEOUT=300

# 本地 LLM（llama-server，替代 Flash 层）
# 需要先启动 llama-server: llama-server -m model.gguf -ngl 99 -c 4096 --port 8080
# LLAMA_SERVER_ENABLED=true
# LLAMA_SERVER_URL=http://127.0.0.1:8080
# 本地模型上下文窗口大小（需匹配 llama-server -c 参数），默认 4096
# LLAMA_MAX_CONTEXT=4096

# ============ 通知配置（可选） ============
# 策略引擎检测到信号后推送通知，配置对应变量后自动启用

# Slack 推送
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ============ 盯盘助手 ============
WATCH_INTERVAL_MINUTES=1
# 盘中极值告警冷却时间（分钟），同一股票同方向突破在冷却期内只推一次
WATCH_ALERT_COOLDOWN_MINUTES=5

# ============ 新闻看板 ============
NEWS_INTERVAL_MINUTES=10
# 启用衍生搜索（crawl4ai 爬取关联新闻 + AI 摘要），默认关闭
NEWS_DERIVATION_ENABLED=false

# 公司新闻爬取（每次轮询最多处理的公司数，默认 3）
# COMPANY_NEWS_MAX_COMPANIES=3
# 每个公司最多爬取文章数，默认 5
# COMPANY_NEWS_MAX_ARTICLES=5
# 公司新闻获取间隔（分钟），默认 30
# COMPANY_NEWS_INTERVAL_MINUTES=30
# 新闻源获取超时（秒），默认 15
# NEWS_FETCH_TIMEOUT=15
# 新闻推送去重窗口（分钟），默认 1440（24小时）
# NEWS_DEDUP_WINDOW_MINUTES=1440

# ============ 赛事推送 ============
# 每日推送中展示 NBA / LoL 赛程和结果
# ESPORTS_ENABLED=true
# 赛事 API 请求超时（秒），默认 15
# ESPORTS_FETCH_TIMEOUT=15
