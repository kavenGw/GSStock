# GSStock 环境配置示例
# 复制此文件为 .env 并修改配置

# ============ 只读模式 ============
# 只读模式下：不从服务器获取数据，不修改 stock.db，但可以修改 private.db
# 适用于无网络环境或仅查看历史数据
READONLY_MODE=false

# ============ 密钥配置 ============
# Flask 密钥，用于 session 加密，留空则自动生成
SECRET_KEY=

# ============ 数据库配置 ============
# 公共数据库路径（股票列表、缓存、分类）
# DATABASE_URL=sqlite:///data/stock.db

# 私有数据库路径（持仓、交易、配置）
# PRIVATE_DATABASE_URL=sqlite:///data/private.db

# ============ CockroachDB 云数据库（可选） ============
# 配置后将使用 CockroachDB 替代本地 stock.db
# ⚠️ 注意：如果本地 stock.db 存在且不为空，启动时会自动迁移数据到云端并删除本地数据库
# 格式: cockroachdb://username:password@host:port/database?sslmode=verify-full
# private.db 不受影响，始终使用本地 SQLite
# COCKROACH_URL=

# ============ 数据源 API 密钥（可选） ============
# A股数据源（新浪/腾讯/东方财富）无需密钥，开箱即用
# 美股/港股默认使用 yfinance（无需密钥），配置以下密钥可启用多数据源负载均衡

# Twelve Data — 免费: 8请求/分钟, 800请求/天（美股/港股）
# 注册: https://twelvedata.com/register
# TWELVE_DATA_API_KEY=

# Polygon.io — 免费: 5请求/分钟（仅美股）
# 注册: https://polygon.io/dashboard/signup
# POLYGON_API_KEY=

# ============ LLM 分析配置（可选） ============
# 智谱 GLM 大模型，配置后自动启用 AI 分析功能
# Flash 层 (glm-4-flash): 快速任务
# Premium 层 (glm-4): 深度分析，预算用尽自动降级到 Flash
# ZHIPU_API_KEY=

# LLM 日预算上限（美元），不配置则无上限
# LLM_DAILY_BUDGET=5.0

# LLM API 请求超时（秒），默认 300
# LLM_REQUEST_TIMEOUT=300

# ============ 通知配置（可选） ============
# 策略引擎检测到信号后推送通知，配置对应变量后自动启用

# Slack 推送
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ============ 盯盘助手 ============
WATCH_INTERVAL_MINUTES=1

# ============ 新闻看板 ============
NEWS_INTERVAL_MINUTES=10

